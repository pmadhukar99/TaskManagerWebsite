{
  "name": "task-manager-backend",
  "description": "Task Manager Backend API",
  "keywords": ["node", "express", "mongodb"],
  "repository": "https://github.com/YOUR_USERNAME/TaskManagerWebsite",
  "engines": {
    "node": "18.x"
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "env": {
    "MONGODB_URI": {
      "description": "MongoDB connection string",
      "required": true
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT tokens",
      "required": true,
      "value": "your-secure-secret-key"
    },
    "NODE_ENV": {
      "value": "production"
    }
  }
}
